# ─────────────────────────────────────────────────────────────
# 환경변수 템플릿
# 이 파일을 .env로 복사한 뒤 실제 값을 채워 사용하세요.
#   cp .env.example .env
# .env는 자격증명을 포함하므로 절대 커밋하지 마세요(.gitignore 권장).
# ⚠️ 이 템플릿(.env.example)에는 실제 키를 절대 적지 마세요(커밋 대상).
# ─────────────────────────────────────────────────────────────

# FRED(경제지표) API 키
FRED_API_KEY=

# S3 접근용 AWS 자격증명 (모델 산출물 다운로드)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 모델 산출물(pkl/csv)이 저장된 S3 버킷 이름
S3_BUCKET_NAME=
